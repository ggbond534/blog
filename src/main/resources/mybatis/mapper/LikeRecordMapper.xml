<?xml version="1.0" encoding="UTF-8" ?>
<!--
    LikeRecordMapper.xml - 点赞记录表 MyBatis SQL 映射文件
    命名空间：com.blog.mapper.LikeRecordMapper
    功能：点赞记录增删查，通过 (articleId + userId) 组合条件操作
-->
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.blog.mapper.LikeRecordMapper">

    <!-- 插入点赞记录 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO like_record (article_id, user_id, create_time)
        VALUES (#{articleId}, #{userId}, #{createTime})
    </insert>

    <!--
        根据文章ID和用户ID删除点赞记录
        组合条件确保只删除当前用户对指定文章的点赞
    -->
    <delete id="deleteByArticleIdAndUserId">
        DELETE FROM like_record WHERE article_id = #{articleId} AND user_id = #{userId}
    </delete>

    <!--
        根据文章ID和用户ID查询点赞记录
        用于判断用户是否已对某篇文章点赞
    -->
    <select id="findByArticleIdAndUserId" resultType="com.blog.entity.LikeRecord">
        SELECT * FROM like_record WHERE article_id = #{articleId} AND user_id = #{userId}
    </select>

    <select id="findByUserId" resultType="com.blog.entity.LikeRecord">
        SELECT * FROM like_record WHERE user_id = #{userId}
    </select>
</mapper>
