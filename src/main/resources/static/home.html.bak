<!--
    index.html - 青栈博客入口
    登录 / 注册页面，访问项目首先进入此页
    登录成功后跳转到 home.html
-->
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>青栈博客 — 欢迎</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/auth.css">
</head>
<body>
<!-- 樱花树背景 -->
<div class="cherry-blossom-scene">
    <svg class="sakura-tree" viewBox="0 0 500 700" xmlns="http://www.w3.org/2000/svg">
        <defs>
            <radialGradient id="petalPink" cx="35%" cy="35%">
                <stop offset="0%" stop-color="#FFD1DC"/><stop offset="40%" stop-color="#FFB7C5"/>
                <stop offset="80%" stop-color="#F48FB1"/><stop offset="100%" stop-color="#E91E63" stop-opacity="0.3"/>
            </radialGradient>
            <radialGradient id="petalLight" cx="35%" cy="35%">
                <stop offset="0%" stop-color="#FFE4E9"/><stop offset="50%" stop-color="#FFCFD8"/>
                <stop offset="100%" stop-color="#FFB7C5" stop-opacity="0.6"/>
            </radialGradient>
            <radialGradient id="blossomDeep" cx="40%" cy="30%">
                <stop offset="0%" stop-color="#FFD6E0"/><stop offset="30%" stop-color="#F8BBD0"/>
                <stop offset="70%" stop-color="#F06292"/><stop offset="100%" stop-color="#C2185B" stop-opacity="0.3"/>
            </radialGradient>
            <linearGradient id="bark" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="#5D3A1A"/><stop offset="40%" stop-color="#8B5E3C"/>
                <stop offset="70%" stop-color="#6B3A2A"/><stop offset="100%" stop-color="#4A2512"/>
            </linearGradient>
        </defs>
        <path d="M230 700 Q225 600 220 500 Q215 400 225 320 Q230 280 235 250 L265 250 Q270 280 275 320 Q285 400 280 500 Q275 600 270 700 Z" fill="url(#bark)"/>
        <path d="M240 690 Q238 580 242 480 Q244 400 243 320" stroke="#5D3A1A" stroke-width="2" fill="none" opacity="0.5"/>
        <path d="M255 680 Q258 560 254 450 Q252 380 256 300" stroke="#4A2512" stroke-width="1.5" fill="none" opacity="0.4"/>
        <path d="M228 350 Q200 310 160 270 Q130 240 100 220" stroke="url(#bark)" stroke-width="18" fill="none" stroke-linecap="round"/>
        <path d="M165 268 Q140 250 120 240" stroke="url(#bark)" stroke-width="10" fill="none" stroke-linecap="round"/>
        <path d="M140 255 Q110 230 85 215" stroke="url(#bark)" stroke-width="7" fill="none" stroke-linecap="round"/>
        <path d="M258 310 Q290 270 330 230 Q360 200 390 185" stroke="url(#bark)" stroke-width="14" fill="none" stroke-linecap="round"/>
        <path d="M310 245 Q340 230 370 220" stroke="url(#bark)" stroke-width="9" fill="none" stroke-linecap="round"/>
        <path d="M350 210 Q375 195 400 190" stroke="url(#bark)" stroke-width="6" fill="none" stroke-linecap="round"/>
        <path d="M245 270 Q255 220 250 160 Q248 120 245 90" stroke="url(#bark)" stroke-width="12" fill="none" stroke-linecap="round"/>
        <path d="M250 180 Q270 165 290 150" stroke="url(#bark)" stroke-width="8" fill="none" stroke-linecap="round"/>
        <path d="M248 140 Q230 120 210 105" stroke="url(#bark)" stroke-width="6" fill="none" stroke-linecap="round"/>
        <circle cx="95" cy="215" r="38" fill="url(#petalPink)" opacity="0.85"/>
        <circle cx="75" cy="225" r="32" fill="url(#petalLight)" opacity="0.8"/>
        <circle cx="110" cy="205" r="28" fill="url(#blossomDeep)" opacity="0.75"/>
        <circle cx="85" cy="200" r="25" fill="url(#petalPink)" opacity="0.7"/>
        <circle cx="105" cy="230" r="22" fill="url(#petalLight)" opacity="0.8"/>
        <circle cx="395" cy="185" r="42" fill="url(#petalPink)" opacity="0.85"/>
        <circle cx="375" cy="195" r="35" fill="url(#petalLight)" opacity="0.8"/>
        <circle cx="415" cy="175" r="30" fill="url(#blossomDeep)" opacity="0.75"/>
        <circle cx="385" cy="165" r="28" fill="url(#petalPink)" opacity="0.7"/>
        <circle cx="410" cy="200" r="25" fill="url(#petalLight)" opacity="0.8"/>
        <circle cx="370" cy="225" r="22" fill="url(#blossomDeep)" opacity="0.65"/>
        <circle cx="245" cy="85" r="40" fill="url(#petalPink)" opacity="0.85"/>
        <circle cx="225" cy="95" r="33" fill="url(#petalLight)" opacity="0.8"/>
        <circle cx="265" cy="90" r="30" fill="url(#blossomDeep)" opacity="0.75"/>
        <circle cx="240" cy="70" r="26" fill="url(#petalPink)" opacity="0.7"/>
        <circle cx="260" cy="105" r="24" fill="url(#petalLight)" opacity="0.8"/>
        <circle cx="375" cy="218" r="32" fill="url(#petalLight)" opacity="0.8"/>
        <circle cx="360" cy="230" r="26" fill="url(#petalPink)" opacity="0.75"/>
        <circle cx="295" cy="148" r="28" fill="url(#petalPink)" opacity="0.8"/>
        <circle cx="285" cy="160" r="24" fill="url(#petalLight)" opacity="0.75"/>
        <circle cx="308" cy="142" r="22" fill="url(#blossomDeep)" opacity="0.7"/>
        <circle cx="205" cy="102" r="26" fill="url(#petalLight)" opacity="0.78"/>
        <circle cx="195" cy="115" r="20" fill="url(#petalPink)" opacity="0.72"/>
        <ellipse cx="200" cy="698" rx="16" ry="6" fill="url(#petalPink)" opacity="0.5"/>
        <ellipse cx="245" cy="695" rx="12" ry="5" fill="url(#petalLight)" opacity="0.4"/>
        <ellipse cx="280" cy="697" rx="14" ry="5" fill="url(#petalPink)" opacity="0.45"/>
        <ellipse cx="170" cy="696" rx="9" ry="4" fill="url(#blossomDeep)" opacity="0.35"/>
        <ellipse cx="300" cy="694" rx="11" ry="4" fill="url(#petalLight)" opacity="0.4"/>
        <circle cx="160" cy="272" r="8" fill="url(#petalPink)" opacity="0.7"/>
        <circle cx="180" cy="258" r="6" fill="url(#petalLight)" opacity="0.65"/>
        <circle cx="330" cy="228" r="7" fill="url(#petalPink)" opacity="0.7"/>
        <circle cx="345" cy="215" r="6" fill="url(#petalLight)" opacity="0.65"/>
        <circle cx="250" cy="162" r="7" fill="url(#petalPink)" opacity="0.68"/>
        <circle cx="268" cy="135" r="5" fill="url(#petalLight)" opacity="0.6"/>
    </svg>
    <div class="falling-petal"></div><div class="falling-petal"></div><div class="falling-petal"></div><div class="falling-petal"></div>
    <div class="falling-petal"></div><div class="falling-petal"></div><div class="falling-petal"></div><div class="falling-petal"></div>
    <div class="falling-petal"></div><div class="falling-petal"></div><div class="falling-petal"></div><div class="falling-petal"></div>
    <div class="falling-petal"></div><div class="falling-petal"></div><div class="falling-petal"></div><div class="falling-petal"></div>
    <div class="falling-petal"></div><div class="falling-petal"></div><div class="falling-petal"></div><div class="falling-petal"></div>
</div>

<div class="auth-container">
    <!-- ====== 左侧品牌面板 ====== -->
    <div class="auth-left">
        <!-- 点阵地球 -->
        <canvas id="dotMap" class="dot-map"></canvas>
        <div class="auth-brand">
            <div class="auth-logo">🌸</div>
            <h1 class="auth-title">青栈博客</h1>
            <p class="auth-desc">记录思想的光，与世界分享你的故事</p>
            <div class="auth-features">
                <span>📝 优雅写作</span>
                <span>🗂️ 分类管理</span>
                <span>💬 互动评论</span>
            </div>
        </div>
    </div>

    <!-- ====== 右侧表单面板 ====== -->
    <div class="auth-right">
        <!-- 登录表单 -->
        <div id="loginForm" class="auth-form active">
            <div class="form-header">
                <h2>👋 欢迎回来</h2>
                <p>登录你的账号，继续创作之旅</p>
            </div>
            <div class="form-body">
                <label>用户名</label>
                <input id="loginUsername" type="text" placeholder="请输入用户名" autocomplete="username">
                <label>密码</label>
                <div class="password-wrapper">
                    <input id="loginPassword" type="password" placeholder="请输入密码" autocomplete="current-password">
                    <button type="button" class="toggle-pw" id="toggleLoginPw">👁️</button>
                </div>
                <button id="loginBtn" class="auth-submit">
                    <span>登 录</span>
                    <span class="btn-arrow">→</span>
                </button>
            </div>
            <div class="form-footer">
                <p>还没有账号？<a id="switchToRegister" href="javascript:void(0)">立即注册 →</a></p>
            </div>
        </div>

        <!-- 注册表单 -->
        <div id="registerForm" class="auth-form">
            <div class="form-header">
                <h2>🎉 创建账号</h2>
                <p>只需几步，开启你的博客之旅</p>
            </div>
            <div class="form-body">
                <label>用户名</label>
                <input id="regUsername" type="text" placeholder="请输入用户名" autocomplete="username">
                <label>密码</label>
                <div class="password-wrapper">
                    <input id="regPassword" type="password" placeholder="6-32位密码" autocomplete="new-password">
                    <button type="button" class="toggle-pw" id="toggleRegPw">👁️</button>
                </div>
                <label>邮箱</label>
                <input id="regEmail" type="email" placeholder="请输入邮箱（选填）">
                <label>电话</label>
                <input id="regPhone" type="text" placeholder="请输入电话（选填）">
                <button id="registerBtn" class="auth-submit">
                    <span>注 册</span>
                    <span class="btn-arrow">→</span>
                </button>
            </div>
            <div class="form-footer">
                <p>已有账号？<a id="switchToLogin" href="javascript:void(0)">去登录 →</a></p>
            </div>
        </div>
    </div>
</div>

<script src="/js/main.js"></script>
<script src="/js/auth-page.js"></script>
</body>
</html>
